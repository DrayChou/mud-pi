    {
      "id": "RueDesEmbassades",
      "title": "大使馆街",
      "desc": "被封锁线围起来的巷子。一具尸体挂在树上已经三天了，没人来处理。警察局的封锁带在风中飘动。路边的罢工工人用煤炭取暖，眼神空洞又坚定。",
      "exits": { "west": "HotelLobby", "north": "HarbourDocks" }
    },
    {
      "id": "HarbourDocks",
      "title": "港口码头",
      "desc": "锈蚀的起重机，半沉的驳船。码头工人的罢工已经持续了第四十二天。海风里有盐和石油的味道，还有某种说不清楚的绝望。",
      "exits": { "south": "RueDesEmbassades" }
    }
