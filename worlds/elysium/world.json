    {
      "id": "HotelLobby",
      "title": "旅馆大厅",
      "desc": "破旧的前台，招待员用一种奇怪的眼神看你。墙上有一张失踪人口的通缉令。咖啡机发出嘶嘶声，像在抱怨什么。",
      "exits": { "north": "HotelRoom", "east": "RueDesEmbassades" }
