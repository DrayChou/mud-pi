    {
      "id": "occult_journalist",
      "name": "艾琳·莫尔",
      "summary": "追踪失踪教授案的记者，太擅长把谣言挖成事实。",
      "background": "你为了阿卡姆最近的失踪案来到这里。线人说，大学图书馆和港口都有人在夜里搬运不该存在的东西。",
      "motivation": "写出真相，哪怕真相会先毁掉你的理智。",
      "initialStats": {
        "hp": 9,
        "san": 75,
        "luck": 60,
        "brawl": 20
      },
      "initialInventory": [
        "newspaper"
      ],
      "openingHook": "清晨的雾还没散，你已经第三次读到同一则失踪新闻。"
    },
    {
      "id": "missing_professor_kin",
      "name": "丹尼尔·韦特",
      "summary": "失踪教授的亲属，带着私人信件来到阿卡姆。",
      "background": "你的叔父在米斯卡托尼克大学任教，最后一封信里只写着「别让他们把书带去海边」。",
      "motivation": "找到叔父，或者至少找出他在害怕什么。",
      "initialStats": {
        "hp": 10,
        "san": 85,
        "luck": 45,
        "brawl": 30
      },
      "initialInventory": [
        "newspaper"
      ],
      "openingHook": "煤气灯下，你认出了报纸照片里叔父那顶旧帽子。"
    }
  ],
  "rooms": [
    {
      "id": "ArkhamStreet",
      "title": "阿卡姆 — 黑暗大街",
      "desc": "1920年代的新英格兰小城。煤气灯在雾中摇曳，鹅卵石街道上几乎看不见行人。报纸头条写着最近的失踪事件，墨迹仿佛还未干透。",
      "exits": {
        "north": "MiskULibrary",
        "east": "HarborsideWharf"
      },
      "tags": [
        "start",
        "outdoor"
      ]
    },
    {
      "id": "MiskULibrary",
      "title": "米斯卡托尼克大学图书馆",
      "desc": "书架延伸至黑暗中，古老的皮革与霉味混杂。某些书架用铁链锁着，标签上写着「限制阅览」。馆员的眼睛似乎比常人更大一些。",
      "exits": {
        "south": "ArkhamStreet"
      }
    },
    {
      "id": "HarborsideWharf",
      "title": "港口码头",
      "desc": "腐烂的木板，停泊的渔船。夜里可以听到从深海传来的击打声，节奏不像任何已知的生命形式。水面上漂着某种不明的黏液。",
      "exits": {
        "west": "ArkhamStreet"
      }
    }
  ],
