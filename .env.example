# ── Prerequisites ─────────────────────────────────────────────
# Default backend: Pi SDK. Install and configure Pi first: https://pi.dev
# Official Pi install options:
#   npm install -g --ignore-scripts @earendil-works/pi-coding-agent
#   curl -fsSL https://pi.dev/install.sh | sh
# Then run `pi` and use /login or your preferred Pi provider setup.
#
# Codex-compatible backend: if your customer only has Codex, install/login Codex:
#   codex login
# Then set AI_BACKEND=codex below.

# ── AI Backend Selection ───────────────────────────────────────
# pi    = use Pi SDK model registry/auth (default)
# codex = use local Codex CLI via `codex exec`
AI_BACKEND=pi

# Optional role-specific override. Leave commented to inherit AI_BACKEND.
# DM_BACKEND=pi
# INTERPRETER_BACKEND=pi
# CHARACTER_BACKEND=pi

# ── Pi Model Selection ─────────────────────────────────────────
# Used when the corresponding backend is `pi`.
# Run `pi` then /model to see available providers and model IDs.

# DM model — stronger model, handles narrative + world building
DM_PROVIDER=openai-proxy
DM_MODEL=claude-sonnet-4.6

# Interpreter model — cheaper/smaller model for stateless command parsing
INTERPRETER_PROVIDER=openai-proxy
INTERPRETER_MODEL=gpt-5.4-mini

# ── Codex Model Selection ──────────────────────────────────────
# Used when the corresponding backend is `codex`.
# Leave blank/commented to use the user's Codex default model.
# CODEX_MODEL=gpt-5.1
# CODEX_DM_MODEL=gpt-5.1
# CODEX_INTERPRETER_MODEL=gpt-5.1-mini
# CODEX_CHARACTER_MODEL=gpt-5.1

# DM thinking depth: off | minimal | low | medium | high
# Pi maps this to provider thinking settings; Codex receives the same task prompt but manages reasoning itself.
DM_THINKING=low

# ── Game Settings ──────────────────────────────────────────────
# World pack to load (worlds/{WORLD_PACK}/world.json)
WORLD_PACK=station-dream

# Default player name in non-interactive CLI mode
DEFAULT_PLAYER_NAME=旅行者
